App(
    appid="batch_ndef_writer",
    name="Batch NDEF Writer",
    apptype=FlipperAppType.EXTERNAL,
    targets=["f7"],
    entry_point="batch_ndef_writer_app",
    stack_size=4 * 1024,
    requires=["gui", "storage", "notification", "dialogs"],
    fap_category="NFC",
    fap_icon="images/icon.png",
    fap_icon_assets="images",
    fap_author="batch_writer",
    fap_version="1.0",
    fap_description="Batch-write NDEF URI records from urls.txt onto NTAG21x tags",
)
